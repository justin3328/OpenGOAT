{
  "name": "opengoat",
  "version": "1.0.0",
  "description": "The GOAT path to any goal. Displacement scoring, ranked paths, AI missions.",
  "type": "module",
  "bin": {
    "opengoat": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.0.0",
    "groq-sdk": "^0.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "boxen": "^7.1.1",
    "ora": "^8.0.1",
    "conf": "^12.0.0",
    "inquirer": "^9.0.0",
    "ink": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "zod": "^3.22.0",
    "express": "^4.19.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/express": "^4.17.0",
    "@types/react": "^18.0.0",
    "vitest": "^1.4.0",
    "eslint": "^8.57.0"
  },
  "keywords": [
    "cli",
    "goal",
    "productivity",
    "ai",
    "missions",
    "habit-tracker",
    "goal-tracker",
    "opengoat",
    "displacement"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
