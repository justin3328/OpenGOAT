{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@opengoat/ink-ui": ["packages/ink-ui/src/index.tsx"],
      "@opengoat/ink-ui/*": ["packages/ink-ui/src/*"]
    },
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "packages/ink-ui/src/**/*"],
}
